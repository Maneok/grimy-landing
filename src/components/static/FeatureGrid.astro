---
import GedAutoCard from '../interactive/GedAutoCard.tsx';
import EquipeAnimated from '../interactive/EquipeAnimated.tsx';
import AlertesLive from '../interactive/AlertesLive.tsx';
---
<section id="plateforme" class="max-w-[1280px] mx-auto px-6 py-24">
  <div class="text-center mb-14 reveal">
    <div class="text-[12px] font-semibold uppercase tracking-[.18em] mb-3" style="color:var(--grimy-dark)">04 — Plateforme</div>
    <h2 class="wordmark text-[clamp(40px,5vw,56px)] leading-[1] tracking-[-.04em] text-slate-900 dark:text-white text-balance">Tout, <span class="text-slate-400 dark:text-slate-500">au même endroit.</span></h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4">

    <!-- 01 — GED automatique (col-span-8, row-span-2) -->
    <div class="bento bento-border md:col-span-8 md:row-span-2 reveal p-9 relative overflow-hidden" style="min-height:520px">
      <span class="bento-num absolute -bottom-8 -right-2 select-none">01</span>
      <div class="relative">
        <div class="text-[10px] uppercase tracking-[.24em] font-bold mb-3 flex items-center gap-2" style="color:var(--grimy-dark)">
          <span>GED automatique</span>
          <span class="px-1.5 py-0.5 rounded text-[9px] font-black tracking-[.12em]" style="background:color-mix(in oklab, var(--grimy) 14%, transparent); color:var(--grimy-dark)">AUTO</span>
        </div>
        <h3 class="wordmark text-[28px] leading-[1.05] tracking-[-.03em] text-slate-900 dark:text-white mb-2">
          Tu balances tes docs.<br>GRIMY range tout seul.
        </h3>
        <p class="text-[12.5px] text-slate-500 dark:text-slate-400 max-w-[420px] mb-6">
          KBIS, CNI, RIB, Statuts, RBE — uploadés, analysés par OCR, classés par client.
          <strong class="text-slate-700 dark:text-slate-200">Vérification temps réel</strong> avec les bases INPI.
        </p>
      </div>
      <GedAutoCard client:visible />
    </div>

    <!-- 02 — Équipe formée (col-span-4) -->
    <div class="bento bento-border md:col-span-4 reveal p-7 relative overflow-hidden">
      <span class="bento-num absolute -bottom-10 -right-3 select-none" style="font-size:140px">02</span>
      <div class="relative">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mb-3" style="color:var(--grimy-dark)">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <h3 class="text-[17px] font-bold text-slate-900 dark:text-white tracking-tight">Équipe formée.</h3>
        <p class="text-[11.5px] text-slate-500 dark:text-slate-400 mt-1 leading-snug mb-3">
          Rôles & habilitations en un coup d'œil.
        </p>
        <EquipeAnimated client:visible />
      </div>
    </div>

    <!-- 03 — Alertes & Revues (col-span-4) -->
    <div class="bento bento-border md:col-span-4 reveal p-7 relative">
      <span class="bento-num absolute -bottom-10 -right-3 select-none" style="font-size:140px">03</span>
      <div class="relative">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mb-3" style="color:var(--grimy-dark)">
          <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
          <path d="M10 21a2 2 0 0 0 4 0"/>
        </svg>
        <h3 class="text-[17px] font-bold text-slate-900 dark:text-white tracking-tight">Alertes & revues.</h3>
        <p class="text-[11.5px] text-slate-500 dark:text-slate-400 mt-1 leading-snug mb-3">
          On te prévient. Tu n'as plus à chercher.
        </p>
        <AlertesLive client:visible />
      </div>
    </div>

  </div>
</section>
