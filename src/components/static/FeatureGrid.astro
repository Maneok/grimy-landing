---
const checkSvg = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>';
---
<section id="plateforme" class="max-w-[1280px] mx-auto px-6 py-24">
  <div class="text-center mb-14 reveal">
    <div class="text-[12px] font-semibold uppercase tracking-[.18em] mb-3" style="color:var(--grimy-dark)">04 — Plateforme</div>
    <h2 class="wordmark text-[clamp(40px,5vw,56px)] leading-[1] tracking-[-.04em] text-slate-900 dark:text-white text-balance">Tout, <span class="text-slate-400 dark:text-slate-500">au même endroit.</span></h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-6 gap-4 auto-rows-[minmax(180px,auto)]">

    <!-- 01 — Risque (4x2) -->
    <div class="bento bento-border md:col-span-4 md:row-span-2 reveal p-9 relative" style="min-height:380px">
      <span class="bento-num absolute -bottom-8 -right-2 select-none">01</span>
      <div class="relative">
        <div class="text-[10px] uppercase tracking-[.24em] font-bold mb-3 flex items-center gap-2" style="color:var(--grimy-dark)">
          <span>Calcul du risque</span>
          <span class="px-1.5 py-0.5 rounded text-[9px] font-black tracking-[.12em]" style="background:color-mix(in oklab, var(--grimy) 14%, transparent); color:var(--grimy-dark)">NPLAB</span>
        </div>
        <h3 class="wordmark text-[28px] leading-[1.05] tracking-[-.03em] text-slate-900 dark:text-white mb-2">Le score se calcule<br/>tout seul.</h3>
        <p class="text-[12.5px] text-slate-500 dark:text-slate-400 max-w-[420px]">Pondération sur les <strong class="text-slate-700 dark:text-slate-200">5 axes NPLAB</strong> — pays, activité, client, opération, distribution.</p>
      </div>
      <div class="relative mt-6 flex items-end gap-7">
        <svg width="200" height="120" viewBox="0 0 200 110" class="shrink-0">
          <path d="M20 100 A 80 80 0 0 1 180 100" fill="none" stroke="#e5e7eb" stroke-width="16" stroke-linecap="round"/>
          <path d="M20 100 A 80 80 0 0 1 180 100" fill="none" stroke="var(--grimy-dark)" stroke-width="16" stroke-linecap="round" stroke-dasharray="148 251" class="bar-fill"/>
          <text x="100" y="82" text-anchor="middle" font-size="42" font-weight="900" class="num" fill="currentColor">58</text>
          <text x="100" y="103" text-anchor="middle" font-size="11" fill="#94a3b8" class="num">/ 100 &middot; STANDARD</text>
        </svg>
        <div class="flex-1 grid grid-cols-3 gap-3 pb-3">
          <div>
            <div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400">Tendance</div>
            <div class="text-[18px] font-bold text-emerald-600 num inline-flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>+4
            </div>
          </div>
          <div><div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400">Revue</div><div class="text-[18px] font-bold text-slate-900 dark:text-white num">8 j</div></div>
          <div><div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400">Alertes</div><div class="text-[18px] font-bold text-amber-600 num">2</div></div>
        </div>
      </div>
      <div class="relative mt-4 pt-3 border-t border-slate-200 dark:border-white/[.06] flex items-center gap-3 text-[10.5px] text-slate-500 dark:text-slate-400 num">
        <span class="inline-flex items-center gap-1"><span class="w-1 h-1 rounded-full bg-emerald-500"></span>Conforme arrêté 6 janvier 2021</span>
        <span class="opacity-30">&middot;</span>
        <span>Norme NPLAB CSOEC</span>
      </div>
    </div>

    <!-- 02 — Parcours (2x1) -->
    <div class="bento bento-border md:col-span-2 reveal p-7 relative">
      <span class="bento-num absolute -bottom-10 -right-3 select-none" style="font-size:140px">02</span>
      <div class="relative">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mb-4" style="color:var(--grimy-dark)"><rect width="8" height="8" x="3" y="3" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect width="8" height="8" x="13" y="13" rx="2"/></svg>
        <h3 class="text-[17px] font-bold text-slate-900 dark:text-white tracking-tight">Parcours guidés.</h3>
        <div class="mt-4 flex items-center gap-1.5">
          {[true, true, false, false].map((d, i) => (
            <>
              <div class={`w-3 h-3 rounded-full ${d ? 'bg-emerald-500' : i === 2 ? 'mint-pulse' : 'bg-slate-200 dark:bg-white/[.08]'}`} style={i === 2 ? 'background:var(--grimy-dark)' : ''}></div>
              {i < 3 && <div class={`flex-1 h-px ${d ? 'bg-emerald-300' : 'bg-slate-200 dark:bg-white/[.08]'}`}></div>}
            </>
          ))}
        </div>
      </div>
    </div>

    <!-- 03 — GED (2x1) -->
    <div class="bento bento-border md:col-span-2 reveal p-7 relative">
      <span class="bento-num absolute -bottom-10 -right-3 select-none" style="font-size:140px">03</span>
      <div class="relative">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mb-3" style="color:var(--grimy-dark)"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
        <h3 class="text-[17px] font-bold text-slate-900 dark:text-white tracking-tight">GED automatique.</h3>
        <p class="text-[11.5px] text-slate-500 dark:text-slate-400 mt-1 leading-snug">KBIS, statuts, RBE — rangés tout seuls.</p>
        <div class="mt-3 space-y-1">
          {[
            { ext: 'KBIS', tag: 'KBIS · à jour', tone: 'ok' },
            { ext: 'PDF', tag: 'Statuts SAS', tone: 'ok' },
            { ext: 'RBE', tag: 'Bénéficiaires effectifs', tone: 'pulse' },
          ].map(d => (
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-md bg-slate-50 dark:bg-white/[.04] border border-slate-200 dark:border-white/[.06]">
              <span class="w-7 h-5 rounded-sm flex items-center justify-center text-[8px] font-black text-white num shrink-0" style={`background: ${d.tone === 'pulse' ? 'var(--grimy-dark)' : '#475569'}`}>{d.ext}</span>
              <span class="text-[10.5px] text-slate-700 dark:text-slate-200 flex-1 truncate font-medium">{d.tag}</span>
              {d.tone === 'ok'
                ? <span class="text-emerald-500 shrink-0" set:html={checkSvg} />
                : <span class="w-1.5 h-1.5 rounded-full mint-pulse shrink-0" style="background:var(--grimy-dark)"></span>}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 04 — Alertes (2x1) -->
    <div class="bento bento-border md:col-span-2 reveal p-7 relative">
      <span class="bento-num absolute -bottom-10 -right-3 select-none" style="font-size:140px">04</span>
      <div class="relative">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mb-4" style="color:var(--grimy-dark)"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
        <h3 class="text-[17px] font-bold text-slate-900 dark:text-white tracking-tight">Alertes & revues.</h3>
        <div class="mt-3 space-y-1">
          {[{ c: '#ef4444', t: 'OFAC' }, { c: '#f59e0b', t: 'Dirigeant changé' }, { c: '#10b981', t: 'Revue OK' }].map(a => (
            <div class="flex items-center gap-2 py-1">
              <span class="w-1.5 h-1.5 rounded-full" style={`background:${a.c}`}></span>
              <span class="text-[11px] text-slate-700 dark:text-slate-300 flex-1 truncate">{a.t}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 05 — Équipe (2x1) -->
    <div class="bento bento-border md:col-span-2 reveal p-7 relative overflow-hidden">
      <span class="bento-num absolute -bottom-10 -right-3 select-none" style="font-size:140px">05</span>
      <div class="relative">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mb-3" style="color:var(--grimy-dark)"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <h3 class="text-[17px] font-bold text-slate-900 dark:text-white tracking-tight">Équipe formée.</h3>
        <p class="text-[11.5px] text-slate-500 dark:text-slate-400 mt-1 leading-snug">Rôles & habilitations en un coup d'œil.</p>
        <svg viewBox="0 0 220 92" class="w-full mt-3 h-[78px]" preserveAspectRatio="xMidYMid meet">
          <line x1="110" y1="22" x2="40" y2="62" stroke="currentColor" stroke-width="1" class="text-slate-300 dark:text-white/[.12]"/>
          <line x1="110" y1="22" x2="110" y2="62" stroke="currentColor" stroke-width="1" class="text-slate-300 dark:text-white/[.12]"/>
          <line x1="110" y1="22" x2="180" y2="62" stroke="currentColor" stroke-width="1" class="text-slate-300 dark:text-white/[.12]"/>
          <g><circle cx="110" cy="14" r="11" fill="var(--grimy-dark)"/><text x="110" y="17" text-anchor="middle" font-size="8" font-weight="800" fill="white" class="num">MC</text><text x="110" y="34" text-anchor="middle" font-size="7.5" font-weight="700" fill="currentColor" class="text-slate-700 dark:text-slate-200">Associé &middot; Décl.</text></g>
          {[{ x: 40, c: '#3b82f6', i: 'SF', r: 'Manager' }, { x: 110, c: '#a855f7', i: 'LP', r: 'Collab.' }, { x: 180, c: '#f59e0b', i: 'AB', r: 'Collab.' }].map(p => (
            <g><circle cx={p.x} cy="70" r="9" fill={p.c}/><text x={p.x} y="73" text-anchor="middle" font-size="7.5" font-weight="800" fill="white" class="num">{p.i}</text><text x={p.x} y="89" text-anchor="middle" font-size="7" fill="currentColor" class="text-slate-500 dark:text-slate-400">{p.r}</text></g>
          ))}
        </svg>
        <div class="mt-2 flex items-center justify-between text-[10px] num">
          <span class="text-slate-500 dark:text-slate-400">5 collaborateurs habilités</span>
          <span class="font-bold px-1.5 py-0.5 rounded bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400">100 % formés</span>
        </div>
      </div>
    </div>

  </div>
</section>
