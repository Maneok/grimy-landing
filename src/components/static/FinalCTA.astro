---
---
<section class="max-w-[1280px] mx-auto px-6 py-24">
  <div id="final-cta-card" class="reveal rounded-3xl px-12 py-20 text-center relative overflow-hidden mock-shadow" style="background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%)">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none">
      <span class="absolute w-3 h-3 rounded-full orbit-1" style="background:var(--grimy); box-shadow:0 0 20px var(--grimy)"></span>
      <span class="absolute w-2 h-2 rounded-full orbit-2" style="background:var(--grimy); box-shadow:0 0 14px var(--grimy); opacity:.6"></span>
    </div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full blur-3xl opacity-30" style="background:var(--grimy); transform: translate(40%, -40%)"></div>

    <h2 class="relative wordmark text-[48px] leading-[1.05] tracking-[-.035em] text-white text-balance max-w-3xl mx-auto">
      Mettez le point final à la conformité.<span class="grimy-dot"></span>
    </h2>
    <p class="relative mt-5 text-[17px] text-slate-300 max-w-xl mx-auto"><span class="font-semibold text-white">14 jours d'essai gratuit</span> sur toutes les formules. Configuré en moins d'un café.</p>
    <div class="relative mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="https://app.grimy.fr/auth" class="inline-flex items-center gap-2 text-[15px] font-semibold text-slate-900 px-5 py-3 rounded-lg btn-magnetic hover:scale-[1.02] transition">
        Essayer gratuitement
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <a href="mailto:contact@grimy.fr" class="inline-flex items-center gap-2 text-[15px] font-medium text-white border border-white/20 px-5 py-3 rounded-lg hover:bg-white/[.06] transition">
        Parler à un humain
      </a>
    </div>
    <div class="relative mt-7 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-[12.5px] text-slate-300">
      <span class="flex items-center gap-1.5">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="color:var(--grimy)"><path d="M5 12l5 5L20 7"/></svg>
        Sans engagement
      </span>
      <span class="flex items-center gap-1.5 font-semibold text-white">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="color:var(--grimy)"><path d="M5 12l5 5L20 7"/></svg>
        14 jours offerts
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="color:var(--grimy)"><path d="M5 12l5 5L20 7"/></svg>
        Annulable en 1 clic
      </span>
    </div>
    <!-- FinalCTACursor.tsx will be injected here via slot -->
    <slot />
  </div>
</section>
