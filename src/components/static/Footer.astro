---
---
<footer class="border-t border-slate-200 dark:border-white/[.06] mt-12">
  <div class="max-w-[1280px] mx-auto px-6 py-12 grid md:grid-cols-4 gap-8">
    <div class="md:col-span-1">
      <span class="wordmark text-[20px] text-slate-900 dark:text-white">GRIMY<span class="grimy-dot"></span></span>
      <p class="mt-3 text-[13px] text-slate-600 dark:text-slate-400 leading-[1.6]">La conformité LCB-FT moderne, pour les cabinets d'expertise comptable français.</p>
      <div class="mt-4 inline-flex items-center gap-1.5 text-[11.5px] font-medium px-2.5 py-1 rounded-md text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20">
        <span class="relative flex w-1.5 h-1.5">
          <span class="absolute inset-0 rounded-full bg-emerald-500 live-pulse"></span>
          <span class="relative inline-flex w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        </span>
        Tous les services opérationnels
      </div>
    </div>
    {[
      { title: 'Produit', items: [
        { label: 'Tableau de bord', href: '/#produit' },
        { label: 'Lettre de mission', href: '/#lettre' },
        { label: 'Vérification', href: '/#screening' },
        { label: 'Revue périodique', href: '/#produit' },
        { label: 'Alertes dossiers', href: '/#produit' },
        { label: 'Manuel LAB', href: '/#produit' },
        { label: 'Documents', href: '/#produit' },
        { label: 'Tarifs', href: '/#tarifs' },
      ] },
      { title: 'Cabinet', items: [
        { label: 'À propos', href: '/a-propos' },
        { label: 'Blog', href: '/blog' },
        { label: 'Sécurité', href: '/securite' },
        { label: 'Conformité', href: '/conformite' },
        { label: 'Statut', href: '/statut' },
      ]},
      { title: 'Légal', items: [
        { label: 'CGU', href: '/cgu' },
        { label: 'CGV', href: '/cgv' },
        { label: 'Confidentialité', href: '/rgpd' },
        { label: 'Mentions légales', href: '/mentions-legales' },
      ]},
    ].map(col => (
      <div>
        <div class="text-[12px] uppercase tracking-wider text-slate-600 dark:text-slate-400 font-semibold mb-3">{col.title}</div>
        <ul class="space-y-2">
          {col.items.map(it => <li><a class="text-[13px] text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition" href={it.href}>{it.label}</a></li>)}
        </ul>
      </div>
    ))}
  </div>
  <div class="border-t border-slate-200 dark:border-white/[.06]">
    <div class="max-w-[1280px] mx-auto px-6 py-5 flex flex-wrap items-center justify-between gap-3">
      <div class="text-[12px] text-slate-600 dark:text-slate-400">&copy; 2026 GRIMY — Alexandre DAHAN (EI) &middot; La conformité LCB-FT moderne</div>
      <div class="text-[12px] text-slate-600 dark:text-slate-400 flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 dark:text-emerald-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
        Données hébergées en Europe (UE) &middot; Chiffrement AES-256
      </div>
    </div>
  </div>
</footer>
