---
import HeroPhraseRotator from '../interactive/HeroPhraseRotator.tsx';
---
<section class="relative overflow-hidden hero-bg-light pt-10 pb-14">
  <div class="absolute inset-0 grain pointer-events-none opacity-50"></div>
  <div class="absolute inset-x-0 top-0 h-[640px] grid-anim pointer-events-none"></div>

  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    {Array.from({ length: 8 }).map((_, i) => (
      <span class="absolute w-1 h-1 rounded-full particle"
        style={`background:var(--grimy); left:${10 + i * 11}%; bottom:0; animation-delay:${i * 0.7}s; animation-duration:${4 + (i % 3)}s; opacity:.4`} />
    ))}
  </div>

  <div class="max-w-[1280px] mx-auto px-6 pt-8 relative grid lg:grid-cols-12 lg:gap-8 xl:gap-10 gap-10 items-center">
    <!-- LEFT -->
    <div class="lg:col-span-5">
      <div class="reveal inline-flex items-center mb-6">
        <span class="mint-pulse text-[10px] font-bold uppercase tracking-[.18em] text-white px-2.5 py-1 rounded-full" style="background:var(--grimy-dark)">NEW</span>
      </div>

      <h1 class="reveal wordmark text-[clamp(38px,4.6vw,56px)] leading-[1.05] tracking-[-.045em] text-slate-900 dark:text-white text-balance" id="hero-headline">
        La conformité<br/>LCB-FT,<br/>
        <span class="relative inline-block">
          <HeroPhraseRotator />
          <span class="grimy-dot"></span>
        </span>
      </h1>

      <p class="reveal mt-6 text-[18px] leading-[1.55] text-slate-600 dark:text-slate-300 max-w-xl">
        Pensée pour les professions assujetties.
      </p>

      <!-- Strip professions LCB-FT — badges colorés -->
      <div class="reveal mt-7 flex flex-wrap items-center gap-2.5 max-w-xl">
        <div class="profession-badge inline-flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-full bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20">
          <span class="w-7 h-7 rounded-full bg-emerald-500/15 dark:bg-emerald-500/20 flex items-center justify-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-700 dark:text-emerald-400"><line x1="3" y1="3" x2="3" y2="21"/><rect x="6" y="14" width="3" height="6" fill="currentColor" stroke="none"/><rect x="11" y="10" width="3" height="10" fill="currentColor" stroke="none"/><rect x="16" y="6" width="3" height="14" fill="currentColor" stroke="none"/></svg>
          </span>
          <span class="text-[12.5px] font-semibold text-slate-700 dark:text-slate-200">Experts-comptables</span>
        </div>
        <div class="profession-badge inline-flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-full bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20">
          <span class="w-7 h-7 rounded-full bg-blue-500/15 dark:bg-blue-500/20 flex items-center justify-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700 dark:text-blue-400"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/><path d="M9 11l1.5 1.5L14 9" stroke-width="1.75"/></svg>
          </span>
          <span class="text-[12.5px] font-semibold text-slate-700 dark:text-slate-200">Commissaires aux comptes</span>
        </div>
        <div class="profession-badge inline-flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-full bg-purple-50 dark:bg-purple-500/10 border border-purple-200 dark:border-purple-500/20">
          <span class="w-7 h-7 rounded-full bg-purple-500/15 dark:bg-purple-500/20 flex items-center justify-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-700 dark:text-purple-400"><rect x="5" y="3" width="14" height="18" rx="1"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="9" y1="12" x2="15" y2="12"/><circle cx="12" cy="17" r="2" fill="currentColor" stroke="none"/></svg>
          </span>
          <span class="text-[12.5px] font-semibold text-slate-700 dark:text-slate-200">Notaires</span>
        </div>
        <div class="profession-badge inline-flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-full bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20">
          <span class="w-7 h-7 rounded-full bg-red-500/15 dark:bg-red-500/20 flex items-center justify-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-700 dark:text-red-400"><line x1="12" y1="3" x2="12" y2="21" stroke-width="2"/><path d="M5 8h14"/><path d="M5 8l-2 5h6z" fill="currentColor" stroke="none" opacity="0.3"/><path d="M19 8l2 5h-6z" fill="currentColor" stroke="none" opacity="0.3"/><path d="M5 8l-2 5h6z"/><path d="M19 8l2 5h-6z"/><line x1="9" y1="21" x2="15" y2="21" stroke-width="2"/></svg>
          </span>
          <span class="text-[12.5px] font-semibold text-slate-700 dark:text-slate-200">Avocats</span>
        </div>
        <div class="profession-badge inline-flex items-center gap-2 pl-1.5 pr-3 py-1.5 rounded-full bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20">
          <span class="w-7 h-7 rounded-full bg-amber-500/15 dark:bg-amber-500/20 flex items-center justify-center">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-700 dark:text-amber-400"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </span>
          <span class="text-[12.5px] font-semibold text-slate-700 dark:text-slate-200">Agents immobiliers</span>
        </div>
      </div>

      <div class="reveal mt-8 flex flex-wrap items-center gap-3">
        <a href="https://app.grimy.fr/auth" class="inline-flex items-center gap-2 text-[15px] font-semibold text-white px-5 py-3 rounded-lg btn-magnetic">
          Essayer gratuitement
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <button id="hero-video-btn" aria-label="Voir la démo vidéo" class="group inline-flex items-center gap-2 text-[15px] font-medium text-slate-800 dark:text-slate-200 bg-white/60 dark:bg-white/[.04] backdrop-blur border border-slate-300 dark:border-white/[.08] px-5 py-3 rounded-lg hover:bg-white dark:hover:bg-white/[.06] transition-all">
          <span class="w-6 h-6 rounded-full flex items-center justify-center text-white" style="background:var(--grimy-dark)">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </span>
          Voir la démo (1 min 30)
        </button>
      </div>

      <!-- Trust avatars -->
      <div class="reveal mt-8 flex items-center gap-3">
        <div class="flex -space-x-2">
          {[
            { bg: '#3b82f6', i: 'JM' }, { bg: '#a855f7', i: 'SF' }, { bg: '#f59e0b', i: 'LP' },
            { bg: 'var(--grimy-dark)', i: 'AB' }, { bg: '#ef4444', i: 'MC' },
          ].map((a, idx) => (
            <div class="w-8 h-8 rounded-full ring-2 ring-[#F4F3EE] dark:ring-[#0B1220] flex items-center justify-center text-[10px] font-bold text-white"
              style={`background:${a.bg}; z-index:${5 - idx}`}>{a.i}</div>
          ))}
        </div>
        <div class="text-[12.5px]">
          <div class="font-bold text-slate-700 dark:text-slate-200 flex items-center gap-1.5">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" class="hero-star-pulse" style="color:var(--grimy-dark)"><path d="M12 2l2.6 7.5H22l-6.2 4.5 2.4 7.5L12 17l-6.2 4.5 2.4-7.5L2 9.5h7.4z"/></svg>
            Lancement 2026
          </div>
          <div class="text-slate-600 dark:text-slate-400">Premiers cabinets en accompagnement</div>
        </div>
      </div>

      <!-- Stats -->
      <div class="reveal mt-9 grid grid-cols-3 gap-x-6 max-w-md" id="hero-stats">
        <div>
          <div class="num text-[28px] font-bold text-slate-900 dark:text-white tracking-tight">12 min</div>
          <div class="text-[12px] text-slate-600 dark:text-slate-400">installation</div>
        </div>
        <div>
          <div class="num text-[28px] font-bold text-slate-900 dark:text-white tracking-tight">9 sources</div>
          <div class="text-[12px] text-slate-600 dark:text-slate-400">vérifiées en 3 s</div>
        </div>
        <div class="relative">
          <div class="absolute -top-[14px] left-0 text-[10px] uppercase tracking-[.16em] font-bold text-emerald-600 dark:text-emerald-400 whitespace-nowrap">Gratuit</div>
          <div class="num text-[28px] font-bold text-slate-900 dark:text-white tracking-tight">0&nbsp;&euro;</div>
          <div class="text-[12px] text-slate-600 dark:text-slate-400">pour démarrer</div>
        </div>
      </div>
    </div>

    <!-- RIGHT — HeroDemo.tsx will be slotted. Below lg the dashboard sits
         under the fold, so content-visibility:auto lets the browser skip
         layout/paint until the user scrolls. Above lg it's beside the
         hero copy and must render immediately. -->
    <div class="lg:col-span-7 reveal lg:-mr-2 xl:mr-0 hero-dashboard-slot">
      <slot />
    </div>
  </div>
</section>
