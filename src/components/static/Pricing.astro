---
---
<section id="tarifs" class="max-w-[1360px] mx-auto px-6 py-24">

  <!-- [1] HEADER -->
  <div class="text-center mb-6 reveal">
    <div class="text-[11px] font-bold uppercase tracking-[.2em] mb-4" style="color:var(--grimy-dark)">05 — Tarifs</div>
    <h2 class="wordmark text-[42px] sm:text-[52px] leading-[1.05] tracking-[-.03em] text-slate-900 dark:text-white max-w-3xl mx-auto">
      Pensée par un expert-comptable. Tarifée pour les cabinets.
    </h2>
    <p class="mt-4 text-[16px] text-slate-600 dark:text-slate-300 max-w-2xl mx-auto leading-relaxed">
      GRIMY automatise ce qui vous fait perdre <strong>100 heures par an</strong>. Commencez gratuitement — sans carte bancaire.
    </p>
  </div>

  <!-- [2] PROOF BAR — inchangée -->
  <div class="flex flex-wrap items-center justify-center gap-6 mb-12 py-5 px-8 rounded-2xl bg-slate-50 dark:bg-white/[.03] border border-slate-200/60 dark:border-white/[.06] reveal">
    <div class="flex items-center gap-2">
      <div class="flex -space-x-2">
        {['JM','SF','LP','AB','MC'].map(i => (
          <div class="w-7 h-7 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[9px] font-bold text-white border-2 border-white dark:border-slate-900">{i}</div>
        ))}
      </div>
      <span class="text-[13px] text-slate-600 dark:text-slate-300 font-medium">Rejoints par les premiers cabinets fondateurs</span>
    </div>
    <div class="h-4 w-px bg-slate-200 dark:bg-white/10 hidden sm:block"></div>
    <blockquote class="text-[13px] text-slate-600 dark:text-slate-400 italic max-w-sm">
      "En 3 semaines, GRIMY a remplacé 4 outils dans notre cabinet. On regagne 2 jours par mois."
      <footer class="mt-1 not-italic font-semibold text-slate-700 dark:text-slate-300 text-[12px]">— Cabinet COMPTADEC, Marseille</footer>
    </blockquote>
  </div>

  <!-- Toggle mensuel/annuel — placé juste au-dessus des cartes -->
  <div class="flex flex-col items-center mb-6 reveal">
    <div class="inline-flex items-center gap-2 p-1 rounded-full text-[13px] font-medium bg-slate-200/60 dark:bg-white/[.04]" id="billing-toggle">
      <button onclick="setBilling('monthly')" id="btn-monthly"
        class="px-4 py-1.5 rounded-full transition text-slate-600 dark:text-slate-300">
        Mensuel
      </button>
      <button onclick="setBilling('annual')" id="btn-annual"
        class="px-4 py-1.5 rounded-full transition flex items-center gap-2 bg-white dark:bg-slate-900 shadow-sm text-slate-900 dark:text-white">
        Annuel
        <span class="text-[10.5px] font-bold uppercase px-1.5 py-0.5 rounded text-white" style="background:var(--grimy-dark)">−2 mois</span>
      </button>
    </div>
    <p class="text-[12px] text-slate-500 dark:text-slate-400 mt-2" id="annual-savings">
      Tarification annuelle activée — vous économisez jusqu'à 2 mois.
    </p>
  </div>

  <!-- ══════════════════════════════════════════════════════
       Cartes premium — hauteurs égalisées, micro-animations sur Cabinet Pro
       Ordre desktop : Cabinet+ → Essentiel → Cabinet → Cabinet Pro
  ══════════════════════════════════════════════════════ -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 items-stretch pt-8 mb-8" id="pricing-grid">

    <!-- 1 — CABINET+ (ancre prix, à gauche sur desktop, en dernier sur mobile) -->
    <div class="reveal order-last lg:order-none group relative flex flex-col h-full rounded-2xl border border-slate-200/60 dark:border-white/[.06] bg-white dark:bg-slate-900/60 p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
      <div class="min-h-[28px] mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold whitespace-nowrap bg-purple-50 text-purple-700 dark:bg-purple-500/10 dark:text-purple-400">💎 Cabinets établis</span>
      </div>
      <h3 class="min-h-[36px] text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Cabinet+</h3>
      <div class="min-h-[56px] mb-6">
        <p class="text-[13px] text-slate-600 dark:text-slate-400 leading-snug">Pour les cabinets de 5 à 15 EC</p>
        <p class="text-[12px] italic text-slate-500 dark:text-slate-500 leading-snug mt-0.5">Notre offre la plus complète pour les cabinets exigeants.</p>
      </div>

      <div class="min-h-[80px] flex items-baseline gap-1 leading-none">
        <span class="text-[56px] font-bold tracking-tight text-slate-900 dark:text-white" data-monthly="349" data-annual="299" id="price-plus">299</span>
        <span class="text-[14px] font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap">€ HT/mois</span>
      </div>
      <div class="min-h-[40px] mb-6">
        <p class="text-[11px] text-slate-500 dark:text-slate-500" id="billing-plus">Facturation annuelle · 3 588 €/an</p>
        <p class="text-[11px] text-violet-600 dark:text-violet-400 font-medium">= 0,15€/jour par client suivi</p>
      </div>

      <a href="mailto:contact@grimy.fr?subject=Démo Cabinet+"
        class="w-full mb-6 inline-flex items-center justify-center text-center text-[13px] font-semibold rounded-xl transition px-4 leading-tight h-12 border border-violet-400 text-violet-700 hover:bg-violet-50 dark:border-violet-600 dark:text-violet-300 dark:hover:bg-violet-950/30">
        Demander une démo
      </a>

      <div class="min-h-[32px] mb-4 text-[13px] font-semibold text-slate-700 dark:text-slate-200">Tout Cabinet Pro, plus :</div>
      <ul class="space-y-2 flex-1">
        {[
          "2 000 clients en suivi LCB-FT",
          "400 signatures incluses (0,80€/sig. supp.)",
          "Onboarding 2h en visio avec un EC",
          "Migration assistée de votre portefeuille",
          "Point annuel dédié (1h visio)",
          "Mises à jour réglementaires en avant-première",
        ].map(f => (
          <li class="flex items-start gap-2 text-[13px] leading-snug text-slate-600 dark:text-slate-300">
            <svg class="w-3.5 h-3.5 mt-[3px] shrink-0 text-violet-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
      <p class="mt-auto pt-4 text-[11px] text-slate-500 dark:text-slate-500">Vous remplacez 5 abonnements logiciels en un seul.</p>
    </div>

    <!-- 2 — ESSENTIEL -->
    <div class="reveal group relative flex flex-col h-full rounded-2xl border border-slate-200/60 dark:border-white/[.06] bg-white dark:bg-slate-900/60 p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
      <div class="min-h-[28px] mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold whitespace-nowrap bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400">🟢 Gratuit pour toujours</span>
      </div>
      <h3 class="min-h-[36px] text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Essentiel</h3>
      <p class="min-h-[56px] text-[13px] text-slate-600 dark:text-slate-400 leading-snug mb-6">Pour découvrir GRIMY avec votre premier portefeuille</p>

      <div class="min-h-[80px] flex items-baseline gap-1 leading-none">
        <span class="text-[56px] font-bold tracking-tight text-slate-900 dark:text-white">0</span>
        <span class="text-[14px] font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap">€/mois</span>
      </div>
      <div class="min-h-[40px] mb-6 text-[11px] text-slate-500 dark:text-slate-500">
        Pas de carte bancaire requise.
      </div>

      <a href="https://app.grimy.fr/auth"
        class="w-full mb-6 inline-flex items-center justify-center text-center text-[13px] font-semibold rounded-xl transition px-4 leading-tight h-12 border border-emerald-500 text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-500/10 hover:bg-emerald-100 dark:hover:bg-emerald-500/20">
        Démarrer gratuitement
      </a>

      <div class="min-h-[32px] mb-4"></div>
      <ul class="space-y-2 flex-1">
        {[
          "10 clients en suivi LCB-FT",
          "Conformité LCB-FT complète (rien de bridé)",
          "INPI, Pappers, BODACC, Sanctions, Annuaire",
          "Risk scoring, GED, registre, journal d'audit",
          "3 lettres de mission offertes par mois",
          "(au-delà : 15€ par lettre)",
          "6€ par signature électronique",
        ].map((f, i) => (
          <li class={`flex items-start gap-2 leading-snug ${[5,6].includes(i) ? 'text-slate-400 dark:text-slate-500 text-[11px] pl-5' : 'text-slate-600 dark:text-slate-300 text-[13px]'}`}>
            {![5,6].includes(i) && <svg class="w-3.5 h-3.5 mt-[3px] shrink-0 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>}
            <span>{f}</span>
          </li>
        ))}
      </ul>
      <div class="mt-auto pt-4 text-[11px] text-slate-500 dark:text-slate-500"></div>
    </div>

    <!-- 3 — CABINET -->
    <div class="reveal group relative flex flex-col h-full rounded-2xl border border-slate-200/60 dark:border-white/[.06] bg-white dark:bg-slate-900/60 p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
      <div class="min-h-[28px] mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold whitespace-nowrap bg-orange-50 text-orange-700 dark:bg-orange-500/10 dark:text-orange-400">✦ Cabinets indépendants</span>
      </div>
      <h3 class="min-h-[36px] text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Cabinet</h3>
      <p class="min-h-[56px] text-[13px] text-slate-600 dark:text-slate-400 leading-snug mb-6">Pour les cabinets qui se lancent</p>

      <div class="min-h-[80px] flex items-baseline gap-1 leading-none">
        <span class="text-[56px] font-bold tracking-tight text-slate-900 dark:text-white" data-monthly="99" data-annual="85" id="price-cabinet">85</span>
        <span class="text-[14px] font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap">€ HT/mois</span>
      </div>
      <div class="min-h-[40px] mb-6 text-[11px] text-slate-500 dark:text-slate-500" id="billing-cabinet">
        Facturation annuelle · 1 020 €/an
      </div>

      <a href="https://app.grimy.fr/auth"
        class="w-full mb-6 inline-flex items-center justify-center text-center text-[13px] font-semibold rounded-xl transition px-4 leading-tight h-12 border border-slate-700 text-slate-900 dark:border-slate-400 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-white/[.05]">
        Essayer 30 jours sans engagement
      </a>

      <div class="min-h-[32px] mb-4 text-[13px] font-semibold text-slate-700 dark:text-slate-200">Tout Essentiel, plus :</div>
      <ul class="space-y-2 flex-1">
        {[
          "200 clients en suivi LCB-FT",
          "Lettres de mission ILLIMITÉES",
          "50 signatures incluses (1,50€/sig. supp.)",
          "Revue périodique automatisée",
          "Alertes temps réel (dirigeant, sanctions, BODACC)",
          "Enrichissement Pappers complet",
          "Support email sous 24h ouvrées",
        ].map(f => (
          <li class="flex items-start gap-2 text-[13px] leading-snug text-slate-600 dark:text-slate-300">
            <svg class="w-3.5 h-3.5 mt-[3px] shrink-0" style="color:var(--grimy-dark)" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
      <div class="mt-auto pt-4 text-[11px] text-slate-500 dark:text-slate-500"></div>
    </div>

    <!-- 4 — CABINET PRO (vedette) -->
    <div class="reveal group relative flex flex-col h-full rounded-2xl border-2 border-[#00C896] bg-gradient-to-b from-emerald-50/30 to-white dark:from-emerald-950/30 dark:to-slate-900 p-7 pt-9 animate-float-subtle shadow-[0_0_0_1px_rgba(0,200,150,0.1),0_8px_32px_rgba(0,200,150,0.12)] hover:shadow-[0_0_0_2px_rgba(0,200,150,0.2),0_16px_48px_rgba(0,200,150,0.25)] transition-shadow duration-500 z-10">
      <!-- Badge flottant LE PLUS CHOISI -->
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
        <div class="relative inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-gradient-to-r from-[#00C896] to-[#00E8AA] text-white text-[11px] font-bold tracking-wider shadow-lg shadow-emerald-500/30 overflow-hidden whitespace-nowrap">
          <span class="animate-star-spin">⭐</span>
          <span>LE PLUS CHOISI</span>
          <div class="absolute inset-0 -translate-x-full animate-shine bg-gradient-to-r from-transparent via-white/40 to-transparent"></div>
        </div>
      </div>

      <div class="min-h-[28px] mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold whitespace-nowrap bg-blue-50 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400">🔵 Cabinets en croissance</span>
      </div>
      <h3 class="min-h-[36px] text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Cabinet Pro</h3>
      <p class="min-h-[56px] text-[13px] text-slate-600 dark:text-slate-400 leading-snug mb-6">Pour les cabinets avec collaborateurs</p>

      <div class="min-h-[80px] flex items-baseline gap-1 leading-none">
        <span class="text-[56px] font-bold tracking-tight text-slate-900 dark:text-white" data-monthly="179" data-annual="149" id="price-pro">149</span>
        <span class="text-[14px] font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap">€ HT/mois</span>
      </div>
      <div class="min-h-[40px] mb-6">
        <p class="text-[11px] text-slate-500 dark:text-slate-500" id="billing-pro">Facturation annuelle · 1 788 €/an</p>
        <p class="text-[11px] text-[#00C896] font-semibold">= 0,19€/jour par client suivi</p>
      </div>

      <a href="https://app.grimy.fr/auth"
        class="w-full mb-6 inline-flex items-center justify-center text-center text-[13px] font-semibold rounded-xl transition px-4 leading-tight h-12 bg-[#00C896] hover:bg-[#00B085] text-white shadow-md shadow-emerald-500/20">
        Essayer 30 jours sans engagement
      </a>

      <div class="min-h-[32px] mb-4 text-[13px] font-semibold text-[#00C896]">Tout Cabinet, plus :</div>
      <ul class="space-y-2 flex-1">
        {[
          "800 clients en suivi LCB-FT",
          "Multi-utilisateurs avec rôles (Admin / Collab.)",
          "150 signatures incluses (1€/sig. supp.)",
          "Module Gouvernance & Contrôle qualité",
          "Diagnostic 360° du cabinet",
          "Tableau de bord cockpit avec KPIs",
          "Support prioritaire — réponse sous 4h",
        ].map(f => (
          <li class="flex items-start gap-2 text-[13px] leading-snug text-slate-600 dark:text-slate-300">
            <svg class="w-3.5 h-3.5 mt-[3px] shrink-0 text-[#00C896] transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="2.25" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
      <div class="mt-auto pt-4 text-[11px] text-slate-500 dark:text-slate-500"></div>
    </div>
  </div>

  <!-- Pied de grille — liste d'attente premium (inchangé) -->
  <div class="text-center mb-16 py-5 px-6 rounded-2xl border border-dashed border-slate-200 dark:border-white/[.08] bg-slate-50/50 dark:bg-white/[.02] reveal">
    <p class="text-[14px] text-slate-600 dark:text-slate-400">
      <strong class="text-slate-800 dark:text-slate-200">Plus de 2 000 clients ou plusieurs cabinets ?</strong>
      Nous préparons une API publique et des fonctionnalités multi-sites.
    </p>
    <a href="mailto:contact@grimy.fr?subject=Liste d'attente multi-sites"
      class="inline-block mt-3 text-[13px] font-semibold px-5 py-2 rounded-lg border border-slate-300 dark:border-white/10 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-white/[.04] transition">
      Rejoindre la liste d'attente →
    </a>
  </div>

  <!-- ══════════════════════════════════════════════════════
       CORRECTION 5 — Section Aversion à la perte (améliorée)
  ══════════════════════════════════════════════════════ -->
  <div class="mb-16 reveal bg-slate-50 dark:bg-slate-900/50 rounded-3xl py-12 px-8 sm:py-16 sm:px-12">
    <h3 class="text-[22px] sm:text-[28px] font-bold tracking-tight text-slate-900 dark:text-white mb-2 text-center">
      Sans GRIMY., votre cabinet perd chaque mois
    </h3>
    <p class="text-center text-slate-500 dark:text-slate-400 text-[14px] mb-10 max-w-xl mx-auto">
      Ce que vous dépensez aujourd'hui en temps, outils éparpillés et risques non couverts.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 max-w-5xl mx-auto">
      {[
        { icon: "⏱", value: "22 heures", label: "de saisie manuelle", sub: "≈ 1 760€ de votre temps facturable", bg: "bg-slate-100 dark:bg-slate-800/60 border-slate-200 dark:border-slate-700/50" },
        { icon: "💸", value: "100€", label: "de signatures ext.", sub: "Yousign, DocuSign, outils ponctuels", bg: "bg-amber-50 dark:bg-amber-950/30 border-amber-100 dark:border-amber-800/30" },
        { icon: "📅", value: "2 jours/an", label: "de préparation audit", sub: "Stress, retard, risque d'oubli", bg: "bg-blue-50 dark:bg-blue-950/30 border-blue-100 dark:border-blue-800/30" },
        { icon: "🚨", value: "100 000€", label: "d'amende possible", sub: "En cas de manquement LCB-FT constaté", bg: "bg-red-50 dark:bg-red-950/30 border-red-100 dark:border-red-800/30" },
      ].map(item => (
        <div class={`flex flex-col gap-3 p-5 rounded-2xl border ${item.bg}`}>
          <span class="text-2xl">{item.icon}</span>
          <div>
            <p class="text-[18px] sm:text-[20px] font-black tracking-tight text-slate-900 dark:text-white leading-none">{item.value}</p>
            <p class="text-[12px] sm:text-[13px] font-semibold text-slate-700 dark:text-slate-200 mt-1">{item.label}</p>
            <p class="text-[11px] sm:text-[12px] text-slate-500 dark:text-slate-400 mt-1 leading-snug">{item.sub}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="text-center mt-10 text-[15px] sm:text-[17px] font-semibold text-slate-800 dark:text-slate-200 max-w-2xl mx-auto leading-snug">
      GRIMY. Cabinet&nbsp;:&nbsp;<span style="color:var(--grimy-dark)" class="font-black">99€/mois</span>.
      La vraie question, c'est combien vous coûte aujourd'hui de
      <span class="underline decoration-red-400 underline-offset-4 font-black text-red-600 dark:text-red-400">NE PAS</span> l'avoir&nbsp;?
    </p>
  </div>

  <!-- ══════════════════════════════════════════════════════
       CORRECTION 6 — Section Membres Fondateurs
  ══════════════════════════════════════════════════════ -->
  <div class="mb-4 reveal rounded-3xl border-y border-emerald-200/30 dark:border-emerald-800/20 py-16 sm:py-20 px-8 sm:px-12"
    style="background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 50%, #f0fdf4 50%);">
    <div class="max-w-3xl mx-auto text-center">
      <h3 class="text-[24px] sm:text-[30px] font-bold tracking-tight text-slate-900 dark:text-white mb-3">
        🌟 Programme Membres Fondateurs
      </h3>
      <p class="text-[15px] text-slate-600 dark:text-slate-300 mb-8 max-w-xl mx-auto">
        Les 100 premiers cabinets qui rejoignent GRIMY. bénéficient&nbsp;:
      </p>

      <!-- Liste bénéfices -->
      <ul class="inline-flex flex-col gap-3 text-left mb-10 mx-auto">
        {[
          "Tarif garanti à vie (jamais d'augmentation)",
          "Accès prioritaire aux nouvelles fonctionnalités",
          "Influence directe sur la roadmap produit",
          "Mention dans nos communications (sur demande)",
        ].map(item => (
          <li class="flex items-center gap-3 text-[14px] text-slate-800 dark:text-slate-200">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
            </span>
            {item}
          </li>
        ))}
      </ul>

      <!-- Barre de progression 5/100 -->
      <div class="max-w-xs mx-auto mb-6">
        <div class="flex items-center justify-between text-[13px] mb-2">
          <span class="text-slate-500 dark:text-slate-400">Places utilisées</span>
          <span class="font-black text-emerald-600 dark:text-emerald-400">5 / 100</span>
        </div>
        <div class="w-full h-3 bg-emerald-100 dark:bg-emerald-950/50 rounded-full overflow-hidden">
          <div class="h-full bg-emerald-500 rounded-full transition-all" style="width: 5%"></div>
        </div>
        <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-2">95 places encore disponibles</p>
      </div>

      <!-- CTA -->
      <a href="https://app.grimy.fr/auth"
        class="inline-flex items-center gap-2 text-[14px] font-bold px-6 py-3 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white transition shadow-lg shadow-emerald-500/25">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Réserver ma place fondateur
      </a>
      <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-3">Disponible sur tous les plans payants</p>
    </div>
  </div>

</section>

<script is:inline>
  function setBilling(type) {
    const isAnnual = type === 'annual';
    const btnA = document.getElementById('btn-annual');
    const btnM = document.getElementById('btn-monthly');
    if (isAnnual) {
      btnA.classList.add('bg-white','shadow-sm','text-slate-900','dark:text-white');
      btnA.classList.remove('text-slate-600','dark:text-slate-300');
      btnM.classList.remove('bg-white','shadow-sm','text-slate-900','dark:text-white');
      btnM.classList.add('text-slate-600','dark:text-slate-300');
    } else {
      btnM.classList.add('bg-white','shadow-sm','text-slate-900','dark:text-white');
      btnM.classList.remove('text-slate-600','dark:text-slate-300');
      btnA.classList.remove('bg-white','shadow-sm','text-slate-900','dark:text-white');
      btnA.classList.add('text-slate-600','dark:text-slate-300');
    }
    const savings = document.getElementById('annual-savings');
    if (savings) savings.textContent = isAnnual
      ? "Tarification annuelle activée — vous économisez jusqu'à 2 mois."
      : "Tarification mensuelle — sans engagement.";

    const plans = [
      { id: 'price-cabinet', billing: 'billing-cabinet', monthly: 99,  annual: 85,  annualTotal: '1 020', monthlyTotal: '1 188' },
      { id: 'price-pro',     billing: 'billing-pro',     monthly: 179, annual: 149, annualTotal: '1 788', monthlyTotal: '2 148' },
      { id: 'price-plus',    billing: 'billing-plus',    monthly: 349, annual: 299, annualTotal: '3 588', monthlyTotal: '4 188' },
    ];
    plans.forEach(p => {
      const el = document.getElementById(p.id);
      const bl = document.getElementById(p.billing);
      if (el) el.textContent = isAnnual ? p.annual : p.monthly;
      if (bl) bl.textContent = isAnnual
        ? `Facturation annuelle · ${p.annualTotal} €/an`
        : `Facturation mensuelle · ${p.monthlyTotal} €/an`;
    });
  }
</script>
