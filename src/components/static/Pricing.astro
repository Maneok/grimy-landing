      <div class="min-h-[28px] mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold whitespace-nowrap bg-blue-50 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400">🔵 Cabinets en croissance</span>
      </div>
      <h3 class="min-h-[36px] text-2xl font-bold tracking-tight text-slate-900 dark:text-white">Cabinet Pro</h3>
      <p class="min-h-[56px] text-[13px] text-slate-600 dark:text-slate-400 leading-snug mb-6">Pour les cabinets avec collaborateurs</p>

      <div class="min-h-[80px] flex items-baseline gap-2 leading-none">
        <span class="text-[56px] font-bold tracking-tight text-slate-900 dark:text-white" data-monthly="179" data-annual="149" id="price-pro">149</span>
        <span class="text-[14px] font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap">€ HT/mois</span>
        <span class="text-[22px] font-semibold leading-none line-through decoration-2 text-slate-300 dark:text-slate-600 num" title="Prix public — hors offre de lancement"><span id="pro-anchor">199</span>€</span>
      </div>
      <div class="min-h-[40px] mb-6">
        <p class="text-[11px] text-slate-500 dark:text-slate-500" id="billing-pro">Facturation annuelle · 1 788 €/an</p>
        <p class="text-[11px] text-[#00C896] font-semibold" id="pro-save">Prix public 199€ · −25 % lancement, soit 600 € économisés/an</p>
      </div>

      <!-- Compte à rebours — offre de lancement fondateur (ancre + urgence) -->
      <div class="min-h-[48px] mb-6" id="pro-countdown" data-start="2026-06-10T00:00:00" data-deadline="2026-07-01T00:00:00">
        <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-[#00C896]/[0.08] border border-[#00C896]/25">
          <span class="w-1.5 h-1.5 rounded-full bg-[#00C896] live-pulse shrink-0"></span>
          <span class="text-[10.5px] font-semibold uppercase tracking-wide text-[#00A077] dark:text-[#00E8AA] whitespace-nowrap">Fin de l'offre</span>
          <span class="ml-auto num font-mono text-[12.5px] font-bold text-slate-800 dark:text-white whitespace-nowrap tabular-nums" aria-hidden="true">
            <span id="cd-d">13</span><span class="text-slate-400 dark:text-slate-500 font-normal">j</span>
            <span id="cd-h">00</span><span class="text-slate-400 dark:text-slate-500 font-normal">h</span>
            <span id="cd-m">00</span><span class="text-slate-400 dark:text-slate-500 font-normal">m</span>
            <span id="cd-s">00</span><span class="text-slate-400 dark:text-slate-500 font-normal">s</span>
          </span>
        </div>
        <div class="mt-1.5 h-1 rounded-full bg-slate-200/70 dark:bg-white/10 overflow-hidden">
          <div class="h-full rounded-full bg-gradient-to-r from-[#00C896] to-[#00E8AA] transition-[width] duration-1000 ease-linear" id="cd-bar" style="width:60%"></div>
        </div>
      </div>

      <a href="https://app.grimy.fr/auth"
        class="w-full mb-6 inline-flex items-center justify-center text-center text-[13px] font-semibold rounded-xl transition px-4 leading-tight h-12 bg-[#00C896] hover:bg-[#00B085] text-white shadow-md shadow-emerald-500/20">
        <span>Profiter de l'offre de lancement</span>
      </a>

      <div class="min-h-[32px] mb-4 text-[13px] font-semibold text-[#00C896]">Tout Cabinet, plus :</div>
      <ul class="space-y-2 flex-1">
        {[
          "800 clients en suivi LCB-FT",
          "Multi-utilisateurs avec rôles (Admin / Collab.)",
          "Signature électronique illimitée et gratuite",
          "Module Gouvernance & Contrôle qualité",
          "Diagnostic 360° du cabinet",
          "Tableau de bord cockpit avec KPIs",
