---
<div id="scroll-progress" class="fixed top-0 left-0 right-0 h-[3px] z-50 pointer-events-none">
  <div id="scroll-bar" class="h-full w-0" style="background:linear-gradient(90deg, var(--grimy) 0%, var(--grimy-dark) 100%); box-shadow:0 0 8px var(--grimy); transition:width 100ms"></div>
</div>
<script>
  const bar = document.getElementById('scroll-bar');
  if (bar) {
    const update = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      bar.style.width = max > 0 ? ((h.scrollTop / max) * 100) + '%' : '0%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
