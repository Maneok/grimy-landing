---
<div id="scroll-progress" class="fixed top-0 left-0 right-0 h-[3px] z-50 pointer-events-none">
  <div id="scroll-bar" class="h-full w-full origin-left" style="background:linear-gradient(90deg, var(--grimy) 0%, var(--grimy-dark) 100%); box-shadow:0 0 8px var(--grimy); transform:scaleX(0); will-change:transform"></div>
</div>
<script>
  const bar = document.getElementById('scroll-bar');
  if (bar) {
    let ticking = false;
    const update = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const r = max > 0 ? h.scrollTop / max : 0;
      bar.style.transform = `scaleX(${r})`;
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    // Defer the initial measurement off the critical path; scaleX(0) is fine
    // until the user starts scrolling.
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => requestAnimationFrame(update), { timeout: 1500 });
    } else {
      setTimeout(update, 600);
    }
  }
</script>
