---
const items = [
  ['ISO 27001', 'Certifié sécurité'],
  ['HDS', 'Hébergeur santé'],
  ['RGPD', '100 % conforme'],
  ['🇫🇷 France', 'Données souveraines'],
  ['NPLAB', 'Norme OEC'],
  ['SOC 2', 'Audité Type II'],
];
---
<section class="max-w-[1280px] mx-auto px-6 py-16 reveal">
  <div class="text-center mb-8">
    <div class="text-[11px] uppercase tracking-[.18em] font-semibold text-slate-500 dark:text-slate-400">Sécurité & conformité</div>
  </div>
  <div class="grid grid-cols-3 md:grid-cols-6 gap-3">
    {items.map(([k, v]) => (
      <div class="rounded-xl border border-slate-200 dark:border-white/[.06] bg-white dark:bg-slate-900 p-4 text-center card-lift hover:border-[var(--grimy-dark)] dark:hover:border-[var(--grimy)] transition-all">
        <div class="text-[15px] font-bold text-slate-900 dark:text-white tracking-tight">{k}</div>
        <div class="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">{v}</div>
      </div>
    ))}
  </div>
</section>
