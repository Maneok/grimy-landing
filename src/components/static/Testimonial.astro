---
const stats = [
  ['3 min', "pour rédiger une lettre de mission"],
  ['\u22124 h', "par semaine sur l'organisation"],
  ['100 %', 'lettres de mission signées'],
  ['0', 'dossier oublié ou mal classé'],
];
---
<section class="max-w-[1280px] mx-auto px-6 py-24">
  <div class="reveal grid lg:grid-cols-12 gap-10 items-center">
    <div class="lg:col-span-7 relative">
      <svg width="44" height="34" viewBox="0 0 44 34" class="absolute -top-4 -left-2 opacity-15" style="color:var(--grimy-dark)" fill="currentColor">
        <path d="M0 34V20C0 9 6 0 18 0V8C12 8 9 13 9 18H17V34H0ZM27 34V20C27 9 33 0 44 0V8C39 8 35 13 35 18H44V34H27Z"/>
      </svg>
      <p class="wordmark text-[36px] leading-[1.15] tracking-[-.03em] text-slate-900 dark:text-white text-balance">
        &laquo;&nbsp;Avant GRIMY<span class="grimy-dot"></span>, rédiger une lettre de mission prenait une demi-journée et l'organisation des dossiers nous épuisait.
        Aujourd'hui, <span class="dash-under">la lettre se génère en 3 minutes</span> et tout est rangé tout seul.&nbsp;&raquo;
      </p>
      <div class="mt-7 flex items-center gap-3">
        <div class="w-12 h-12 rounded-full flex items-center justify-center text-[15px] font-bold text-white" style="background:#3b82f6">VC</div>
        <div>
          <div class="text-[15px] font-semibold text-slate-900 dark:text-white">Valentine Charpentier</div>
          <div class="text-[13px] text-slate-500 dark:text-slate-400">Associée — Cabinet Charpentier & Faure (28 collaborateurs &middot; Lyon)</div>
        </div>
      </div>
    </div>
    <div class="lg:col-span-5">
      <div class="grid grid-cols-2 gap-3">
        {stats.map(([k, v]) => (
          <div class="rounded-xl border border-slate-200 dark:border-white/[.06] bg-white dark:bg-slate-900 p-5 card-lift">
            <div class="num text-[26px] font-bold tracking-tight" style="color:var(--grimy-dark)">{k}</div>
            <div class="text-[12.5px] text-slate-600 dark:text-slate-400 leading-snug mt-0.5">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
