---
const stats = [
  ['3 min', "pour rédiger une lettre de mission"],
  ['\u22124 h', "par semaine sur l'organisation"],
  ['100 %', 'lettres de mission signées'],
  ['0', 'dossier oublié ou mal classé'],
];
---
<section class="max-w-[1280px] mx-auto px-6 py-24">
  <div class="reveal grid lg:grid-cols-12 gap-10 items-center">
    <div class="lg:col-span-7 relative">
      <svg width="44" height="34" viewBox="0 0 44 34" class="absolute -top-4 -left-2 opacity-15" style="color:var(--grimy-dark)" fill="currentColor">
        <path d="M0 34V20C0 9 6 0 18 0V8C12 8 9 13 9 18H17V34H0ZM27 34V20C27 9 33 0 44 0V8C39 8 35 13 35 18H44V34H27Z"/>
      </svg>
      <p class="wordmark text-[36px] leading-[1.15] tracking-[-.03em] text-slate-900 dark:text-white text-balance">
        &laquo;&nbsp;Le temps de conformité LCB-FT par client est passé de 4 heures à 12 minutes.
        La revue périodique se fait quasi automatiquement. On a enfin <span class="dash-under">un outil vraiment pensé pour le quotidien d'un cabinet</span>.&nbsp;&raquo;
      </p>
      <div class="mt-7 flex items-center gap-3">
        <div class="w-12 h-12 rounded-full flex items-center justify-center text-[14px] font-bold text-white" style="background:var(--grimy-dark)">EC</div>
        <div>
          <div class="text-[15px] font-semibold text-slate-900 dark:text-white">Expert-comptable</div>
          <div class="text-[13px] text-slate-600 dark:text-slate-400">Cabinet 25+ collaborateurs</div>
          <div class="text-[12px] text-slate-600 dark:text-slate-400 flex items-center gap-1.5">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-emerald-500"><path d="M5 12l5 5L20 7"/></svg>
            Client confidentiel &middot; Région Sud
          </div>
        </div>
      </div>
    </div>
    <div class="lg:col-span-5">
      <div class="grid grid-cols-2 gap-3">
        {stats.map(([k, v]) => (
          <div class="rounded-xl border border-slate-200 dark:border-white/[.06] bg-white dark:bg-slate-900 p-5 card-lift">
            <div class="num text-[26px] font-bold tracking-tight" style="color:var(--grimy-dark)">{k}</div>
            <div class="text-[12.5px] text-slate-600 dark:text-slate-400 leading-snug mt-0.5">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
