---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const url = `https://grimy.fr/blog/${post.id}`;
const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

// JSON-LD Article — déterminant pour être cité par les AI Overviews / ChatGPT Search.
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: post.data.author, url: 'https://grimy.fr' },
  publisher: {
    '@type': 'Organization',
    name: 'GRIMY',
    url: 'https://grimy.fr',
    logo: { '@type': 'ImageObject', url: 'https://grimy.fr/og-grimy-v2.png' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  inLanguage: 'fr-FR',
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://grimy.fr/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://grimy.fr/blog' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<BaseLayout title={`${post.data.title} — GRIMY`} description={post.data.description} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <main class="max-w-3xl mx-auto px-6 py-20">
    <nav class="mb-8 text-sm text-slate-500 dark:text-slate-400">
      <a href="/blog" class="hover:text-slate-900 dark:hover:text-white transition">← Blog</a>
    </nav>

    <article>
      <header class="mb-10">
        <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white leading-tight">
          {post.data.title}
        </h1>
        <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500 dark:text-slate-400">
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{post.data.author}</span>
          {
            post.data.updatedDate && (
              <>
                <span aria-hidden="true">·</span>
                <span>Mis à jour le {fmt(post.data.updatedDate)}</span>
              </>
            )
          }
        </div>
      </header>

      <div
        class="prose prose-slate dark:prose-invert max-w-none prose-headings:text-slate-900 dark:prose-headings:text-white prose-a:text-indigo-600 dark:prose-a:text-indigo-400"
      >
        <Content />
      </div>
    </article>

    <aside
      class="mt-16 rounded-2xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-6"
    >
      <p class="text-slate-900 dark:text-white font-semibold">
        GRIMY automatise votre conformité LCB-FT.
      </p>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
        Vigilance client, scoring de risque, registre des diligences et surveillance continue —
        dans un seul outil pensé pour les cabinets d’expertise comptable.
      </p>
      <a
        href="/#tarifs"
        class="mt-4 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition"
      >
        Découvrir GRIMY
      </a>
    </aside>
  </main>
</BaseLayout>
