---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const url = `https://grimy.fr/blog/${post.id}`;
const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const readingTime = Math.max(1, Math.round((post.body?.trim().split(/\s+/).length ?? 0) / 200));
const initials = post.data.author
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase())
  .join('');
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
const shareX = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(url)}`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: post.data.author, url: 'https://grimy.fr' },
  publisher: {
    '@type': 'Organization',
    name: 'GRIMY',
    url: 'https://grimy.fr',
    logo: { '@type': 'ImageObject', url: 'https://grimy.fr/og-grimy-v2.png' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  inLanguage: 'fr-FR',
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://grimy.fr/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://grimy.fr/blog' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<BaseLayout title={`${post.data.title} — GRIMY`} description={post.data.description} ogType="article" breadcrumb={false}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <div id="read-progress" aria-hidden="true"></div>

  <main class="blog-scope">
    <!-- En-tête -->
    <div class="relative overflow-hidden">
      <div class="absolute inset-0 blog-hero-grid" aria-hidden="true"></div>
      <div class="absolute inset-0 blog-hero-glow" aria-hidden="true"></div>

      <div class="relative max-w-3xl mx-auto px-6 pt-20 pb-10">
        <nav class="mb-8 flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
          <a href="/" class="hover:text-slate-900 dark:hover:text-white transition">Accueil</a>
          <span aria-hidden="true">/</span>
          <a href="/blog" class="hover:text-slate-900 dark:hover:text-white transition">Blog</a>
        </nav>

        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 mb-4">
              {post.data.tags.slice(0, 3).map((t) => (
                <span class="tag-chip">{t}</span>
              ))}
            </div>
          )
        }

        <h1 class="text-3xl md:text-[2.6rem] font-extrabold tracking-tight text-slate-900 dark:text-white leading-[1.12]">
          {post.data.title}
        </h1>

        <div
          class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-slate-500 dark:text-slate-400"
        >
          <span class="author-dot">{initials}</span>
          <span class="font-medium text-slate-700 dark:text-slate-300">{post.data.author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} min de lecture</span>
          {
            post.data.updatedDate && (
              <>
                <span aria-hidden="true">·</span>
                <span>Mis à jour le {fmt(post.data.updatedDate)}</span>
              </>
            )
          }
        </div>
      </div>
    </div>

    <!-- Corps -->
    <article class="max-w-3xl mx-auto px-6 pb-8">
      <div class="blog-prose">
        <Content />
      </div>
    </article>

    <!-- Partage -->
    <div class="max-w-3xl mx-auto px-6">
      <div
        class="flex items-center gap-3 py-6 border-y border-slate-200 dark:border-white/10 text-sm"
      >
        <span class="text-slate-500 dark:text-slate-400 font-medium">Partager</span>
        <a
          href={shareLinkedIn}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Partager sur LinkedIn"
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 hover:border-[#00C896] hover:text-[#00A077] dark:hover:text-[#00E8AA] transition"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.25 8h4.5v14H.25V8zM8.5 8H13v1.9h.06c.63-1.2 2.18-2.46 4.49-2.46 4.8 0 5.69 3.16 5.69 7.27V22h-4.5v-6.18c0-1.47-.03-3.37-2.06-3.37-2.06 0-2.38 1.6-2.38 3.26V22H8.5V8z"
            /></svg
          >
        </a>
        <a
          href={shareX}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Partager sur X"
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 hover:border-[#00C896] hover:text-[#00A077] dark:hover:text-[#00E8AA] transition"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.65l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
            /></svg
          >
        </a>
        <button
          id="copy-link"
          type="button"
          aria-label="Copier le lien"
          class="inline-flex items-center gap-1.5 h-9 px-3 rounded-lg border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 hover:border-[#00C896] hover:text-[#00A077] dark:hover:text-[#00E8AA] transition"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path
              d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
            /></svg
          >
          <span id="copy-label">Copier le lien</span>
        </button>
      </div>
    </div>

    <!-- Bio auteur -->
    <div class="max-w-3xl mx-auto px-6 mt-8">
      <div
        class="flex items-start gap-4 rounded-2xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-5"
      >
        <span class="author-dot shrink-0" style="width:40px;height:40px;font-size:14px;"
          >{initials}</span
        >
        <div>
          <p class="font-semibold text-slate-900 dark:text-white">{post.data.author}</p>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">
            GRIMY accompagne les cabinets d’expertise comptable dans leur conformité
            LCB-FT : vigilance client, scoring de risque et registre des diligences,
            hébergés en Union européenne.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <aside class="max-w-3xl mx-auto px-6 mt-8 mb-24">
      <div
        class="relative overflow-hidden rounded-2xl border border-[#00C896]/30 p-8 text-center"
        style="background:radial-gradient(120% 140% at 50% 0%, rgba(0,200,150,.16), transparent 60%);"
      >
        <p class="text-xl font-bold text-slate-900 dark:text-white">
          Automatisez votre conformité LCB-FT
        </p>
        <p class="mt-2 text-slate-600 dark:text-slate-300 max-w-md mx-auto">
          Vigilance, scoring de risque, registre des diligences et surveillance
          continue — dans un seul outil pensé pour les experts-comptables.
        </p>
        <a
          href="/#tarifs"
          class="mt-5 inline-block rounded-xl bg-[#00C896] hover:bg-[#00A077] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[#00C896]/30 transition"
        >
          Découvrir GRIMY
        </a>
      </div>
      <div class="mt-8 text-center">
        <a
          href="/blog"
          class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-[#00A077] dark:hover:text-[#00E8AA] transition"
        >
          ← Tous les articles
        </a>
      </div>
    </aside>
  </main>

  <script is:inline>
    // Barre de progression de lecture
    const bar = document.getElementById('read-progress');
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      bar.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + '%';
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Copier le lien
    const btn = document.getElementById('copy-link');
    const label = document.getElementById('copy-label');
    btn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const prev = label.textContent;
        label.textContent = 'Lien copié ✓';
        setTimeout(() => (label.textContent = prev), 1800);
      } catch (e) {}
    });
  </script>
</BaseLayout>
