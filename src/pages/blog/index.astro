---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../../styles/blog.css';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const readingTime = (body: string) =>
  Math.max(1, Math.round((body?.trim().split(/\s+/).length ?? 0) / 200));
const initials = (name: string) =>
  name.split(/\s+/).slice(0, 2).map((w) => w[0]?.toUpperCase()).join('');

const [featured, ...rest] = posts;

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog GRIMY — Conformité LCB-FT',
  description:
    'Guides et ressources sur la conformité LCB-FT pour les cabinets d’expertise comptable.',
  url: 'https://grimy.fr/blog',
  publisher: { '@type': 'Organization', name: 'GRIMY', url: 'https://grimy.fr' },
};
---

<BaseLayout
  title="Blog — GRIMY"
  description="Guides pratiques sur la conformité LCB-FT, la vigilance client et les obligations des experts-comptables. Ressources par l'équipe GRIMY."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogLd)} />

  <main class="blog-scope relative">
    <!-- Hero -->
    <div class="relative overflow-hidden">
      <div class="absolute inset-0 blog-hero-grid" aria-hidden="true"></div>
      <div class="absolute inset-0 blog-hero-glow" aria-hidden="true"></div>
      <div class="relative max-w-3xl mx-auto px-6 pt-24 pb-12 text-center">
        <span
          class="inline-flex items-center gap-1.5 text-[11.5px] font-semibold uppercase tracking-[0.14em] px-3 py-1 rounded-full text-[#00A077] dark:text-[#00E8AA] bg-[#E5F8F1] dark:bg-[#0d2820] border border-[#00C896]/25"
        >
          <span class="relative flex w-1.5 h-1.5">
            <span class="absolute inset-0 rounded-full bg-[#00C896] live-pulse"></span>
            <span class="relative inline-flex w-1.5 h-1.5 rounded-full bg-[#00C896]"></span>
          </span>
          Ressources LCB-FT
        </span>
        <h1
          class="mt-5 text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white"
        >
          Le blog GRIMY
        </h1>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-xl mx-auto leading-relaxed">
          Conformité LCB-FT, vigilance client et obligations des cabinets —
          expliquées clairement, pour les experts-comptables.
        </p>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 pb-24">
      {
        posts.length === 0 ? (
          <p class="text-center text-slate-500 dark:text-slate-400 py-20">
            Aucun article publié pour le moment.
          </p>
        ) : (
          <>
            {/* À la une */}
            <a
              href={`/blog/${featured.id}`}
              class="post-card group relative grid md:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-slate-200 dark:border-white/10 bg-white dark:bg-slate-900/40 mb-14"
            >
              <div class="post-cover min-h-[200px] md:min-h-full flex items-center justify-center p-8">
                <svg
                  width="68"
                  height="68"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#00E8AA"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="relative drop-shadow"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </div>
              <div class="p-7 md:p-9 flex flex-col">
                <div class="flex items-center gap-2 mb-3">
                  <span class="tag-chip">À la une</span>
                  {featured.data.tags.slice(0, 1).map((t) => (
                    <span class="tag-chip">{t}</span>
                  ))}
                </div>
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white leading-snug group-hover:text-[#00A077] dark:group-hover:text-[#00E8AA] transition-colors">
                  {featured.data.title}
                </h2>
                <p class="mt-3 text-slate-600 dark:text-slate-300 leading-relaxed line-clamp-3">
                  {featured.data.description}
                </p>
                <div class="mt-auto pt-6 flex items-center gap-3 text-sm text-slate-500 dark:text-slate-400">
                  <span class="author-dot">{initials(featured.data.author)}</span>
                  <span class="font-medium text-slate-700 dark:text-slate-300">
                    {featured.data.author}
                  </span>
                  <span aria-hidden="true">·</span>
                  <time datetime={featured.data.pubDate.toISOString()}>
                    {fmt(featured.data.pubDate)}
                  </time>
                  <span aria-hidden="true">·</span>
                  <span>{readingTime(featured.body)} min</span>
                </div>
              </div>
            </a>

            {/* Grille */}
            {rest.length > 0 && (
              <div class="grid sm:grid-cols-2 gap-6">
                {rest.map((post) => (
                  <a
                    href={`/blog/${post.id}`}
                    class="post-card group relative flex flex-col rounded-2xl overflow-hidden border border-slate-200 dark:border-white/10 bg-white dark:bg-slate-900/40 p-6"
                  >
                    <div class="flex flex-wrap items-center gap-2 mb-3">
                      {post.data.tags.slice(0, 2).map((t) => (
                        <span class="tag-chip">{t}</span>
                      ))}
                    </div>
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white leading-snug group-hover:text-[#00A077] dark:group-hover:text-[#00E8AA] transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-300 leading-relaxed line-clamp-3">
                      {post.data.description}
                    </p>
                    <div class="mt-auto pt-5 flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
                      <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                      <span aria-hidden="true">·</span>
                      <span>{readingTime(post.body)} min de lecture</span>
                      <span class="post-card-arrow ml-auto text-[#00A077] dark:text-[#00E8AA] font-medium">
                        Lire →
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </>
        )
      }
    </div>
  </main>
</BaseLayout>
