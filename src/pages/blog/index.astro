---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog GRIMY — Conformité LCB-FT',
  description:
    'Guides et ressources sur la conformité LCB-FT pour les cabinets d’expertise comptable.',
  url: 'https://grimy.fr/blog',
  publisher: { '@type': 'Organization', name: 'GRIMY', url: 'https://grimy.fr' },
};
---

<BaseLayout
  title="Blog — GRIMY"
  description="Guides pratiques sur la conformité LCB-FT, la vigilance client et les obligations des experts-comptables. Ressources par l'équipe GRIMY."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogLd)} />

  <main class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Blog</h1>
    <p class="text-sm text-slate-500 dark:text-slate-400 mb-12">
      Conformité LCB-FT, vigilance client et obligations des cabinets — expliquées simplement.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-slate-500 dark:text-slate-400">Aucun article publié pour le moment.</p>
      ) : (
        <ul class="space-y-10">
          {posts.map((post) => (
            <li class="border-b border-slate-200 dark:border-white/10 pb-10 last:border-0">
              <a href={`/blog/${post.id}`} class="group block">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400"
                >
                  {fmt(post.data.pubDate)}
                </time>
                <h2 class="mt-2 text-xl font-semibold text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-slate-600 dark:text-slate-300 leading-relaxed">
                  {post.data.description}
                </p>
                <span class="mt-3 inline-block text-sm font-medium text-indigo-600 dark:text-indigo-400">
                  Lire l’article →
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
