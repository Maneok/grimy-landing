---
import '../styles/global.css';

// Static components (zero JS)
import Hero from '../components/static/Hero.astro';
import TrustMarquee from '../components/static/TrustMarquee.astro';
import LettreSection from '../components/static/LettreSection.astro';
import FeatureGrid from '../components/static/FeatureGrid.astro';
import Pricing from '../components/static/Pricing.astro';
import FAQ from '../components/static/FAQ.astro';
import FinalCTA from '../components/static/FinalCTA.astro';
import Footer from '../components/static/Footer.astro';

// Static components converted from React (zero JS framework)
import ScrollProgress from '../components/static/ScrollProgress.astro';
import BackToTopBtn from '../components/static/BackToTop.astro';
import StickyMobileCTABar from '../components/static/StickyMobileCTA.astro';

// Interactive components (hydrated)
import TopNav from '../components/interactive/TopNav.tsx';
import HeroClientsDashboard from '../components/interactive/HeroClientsDashboard.tsx';
import VerificationSection from '../components/interactive/VerificationSection.tsx';
import ScreeningDemo from '../components/interactive/ScreeningDemo.tsx';
import LettreDemo from '../components/interactive/LettreDemo.tsx';
import LiveToast from '../components/interactive/LiveToast.tsx';
import Confetti from '../components/interactive/Confetti.tsx';
import FinalCTACursor from '../components/interactive/FinalCTACursor.tsx';

const title = 'GRIMY. — La conformité LCB-FT, sans prise de tête';
const description = 'Plateforme LCB-FT pour experts-comptables, notaires, avocats et agents immobiliers. Vérification client, lettre de mission, revue périodique.';
const url = 'https://grimy.fr';
const ogImage = `${url}/og-grimy.png`;

const faqItems = [
  { q: 'Êtes-vous conformes à la norme NPLAB ?', a: "Oui. GRIMY couvre l'intégralité des obligations de la norme NPLAB de l'OEC : identification du client, vigilance proportionnée, manuel interne LAB, revues périodiques, conservation 5 ans." },
  { q: 'Comment se passe la migration depuis un autre outil ?', a: "Vous importez vos clients via un fichier CSV ou nos connecteurs cabinet (ACD, RCA). GRIMY récupère automatiquement les données réglementaires depuis l'INPI. Délai moyen : 30 minutes pour 100 clients." },
  { q: 'Mes données sont-elles sécurisées ?', a: "Oui. Les données métier sont hébergées dans l'Union Européenne (Irlande), avec chiffrement AES-256 au repos et TLS 1.3 en transit. Isolation stricte entre cabinets, accès contrôlé par Row-Level Security. Aucune donnée ne transite vers un pays tiers sans encadrement contractuel (CCT)." },
  { q: 'Puis-je essayer sans carte bancaire ?', a: "Oui. L'offre Essentiel est gratuite pour toujours, sans carte bancaire ni engagement : suivez jusqu'à 5 clients avec la conformité LCB-FT complète et 3 lettres de mission offertes. Vous passez à une offre payante uniquement quand vous le décidez, sans engagement et résiliable à tout moment." },
  { q: 'Que se passe-t-il si je dépasse le quota de clients ?', a: "Vous êtes notifié à 80% du quota. À 100%, GRIMY continue de fonctionner pour les clients existants. Vous pouvez upgrader d'un clic." },
  { q: 'Comment se passe la prise en main ?', a: "Tout est intégré au produit, en moins de 15 minutes. Pour les cabinets de plus de 10 utilisateurs, un accompagnant dédié vous aide." },
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin fetchpriority="high" />
    <link rel="icon" type="image/svg+xml" href="/grimy-favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/grimy-favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/grimy-favicon-192.png" />
    <link rel="apple-touch-icon" href="/grimy-favicon-192.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="GRIMY — La conformité LCB-FT, sans stress" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="GRIMY." />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="GRIMY — La conformité LCB-FT, sans stress" />

    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "GRIMY",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "url": url,
      "description": description,
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "0",
        "highPrice": "349",
        "priceCurrency": "EUR",
        "offerCount": "4"
      }
    })} />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "GRIMY",
      "legalName": "Alexandre DAHAN (entreprise individuelle)",
      "url": url,
      "logo": `${url}/grimy-logo-light.png`,
      "email": "contact@grimy.fr",
      "vatID": "FR44947830014",
      "taxID": "947830014",
      "sameAs": [],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Bât. C, 158 rue du Rouet",
        "addressLocality": "Marseille",
        "postalCode": "13008",
        "addressCountry": "FR"
      }
    })} />

    <!-- JSON-LD: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "GRIMY.",
      "url": url,
      "description": description,
      "inLanguage": "fr-FR"
    })} />

    <!-- JSON-LD: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    })} />

    <script is:inline>
      const theme = localStorage.getItem('grimy-theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="text-slate-900 dark:text-slate-100 overflow-x-hidden">
    <!-- Skip link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:text-slate-900 focus:text-sm focus:font-semibold">
      Aller au contenu principal
    </a>

    <div class="min-h-screen">
      <ScrollProgress />
      <TopNav client:idle />

      <main id="main-content">
        <Hero>
          <HeroClientsDashboard client:media="(min-width: 1024px)" />
        </Hero>

        <TrustMarquee />

        <div class="cv-auto">
          <VerificationSection client:visible={{rootMargin: '200px'}} />
        </div>
        <div class="cv-auto">
          <ScreeningDemo client:visible={{rootMargin: '200px'}} />
        </div>

        <div class="cv-auto"><FeatureGrid /></div>

        <div class="cv-auto">
          <LettreSection>
            <LettreDemo client:visible={{rootMargin: '200px'}} />
          </LettreSection>
        </div>

        <div class="cv-auto">
          <Pricing />
        </div>

        <div class="cv-auto"><FAQ /></div>

        <div class="cv-auto">
          <FinalCTA>
            <FinalCTACursor client:visible={{rootMargin: '200px'}} />
          </FinalCTA>
        </div>
      </main>

      <Footer />

      <BackToTopBtn />
      <LiveToast client:idle />
      <StickyMobileCTABar />
      <Confetti client:idle />
    </div>
</body>
</html>
